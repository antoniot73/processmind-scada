        "z": "7599b5e702504de3",
        "name": "Simular tanque termico",
        "func": "msg.topic = \"factory/demo/tank01/telemetry\";\n\nmsg.payload = {\n    asset_id: \"tank01\",\n    timestamp: new Date().toISOString(),\n    temperature_c: 78.5,\n    pressure_bar: 2.1,\n    flow_lpm: 45.2,\n    level_pct: 65.0,\n    heater_power_pct: 70.0,\n    vibration_mm_s: 1.5,\n    energy_kwh: 12.8,\n    product_quality_pct: 93.5\n};\n\nlet telemetryCount = global.get(\"telemetry_count\") || 0;\ntelemetryCount += 1;\n\nglobal.set(\"telemetry_count\", telemetryCount);\nglobal.set(\"last_telemetry_at\", msg.payload.timestamp);\nglobal.set(\"last_telemetry_topic\", msg.topic);\nglobal.set(\"node_red_ready\", true);\n\nreturn msg;",
