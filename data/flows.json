    {
        "id": "healthz_function",
        "type": "function",
        "z": "7599b5e702504de3",
        "name": "Estado Node-RED + Telemetria",
        "func": "const now = new Date();\nconst lastTelemetryAt = global.get(\"last_telemetry_at\") || null;\nconst telemetryCount = global.get(\"telemetry_count\") || 0;\nconst telemetryTopic = global.get(\"last_telemetry_topic\") || \"factory/demo/tank01/telemetry\";\n\nlet ageSeconds = null;\nlet telemetryFresh = false;\n\nif (lastTelemetryAt !== null) {\n    ageSeconds = Math.round((now.getTime() - new Date(lastTelemetryAt).getTime()) / 1000);\n    telemetryFresh = ageSeconds <= 20;\n}\n\nconst isReady = telemetryCount > 0 && telemetryFresh;\n\nmsg.statusCode = isReady ? 200 : 503;\n\nmsg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"Cache-Control\": \"no-store\"\n};\n\nmsg.payload = {\n    service: \"processmind-scada-ml\",\n    status: isReady ? \"READY\" : \"STARTING\",\n    node_red: \"RUNNING\",\n    mqtt_flow: telemetryCount > 0 ? \"ACTIVE\" : \"WAITING_FIRST_TELEMETRY\",\n    telemetry_fresh: telemetryFresh,\n    telemetry_count: telemetryCount,\n    telemetry_topic: telemetryTopic,\n    last_telemetry_at: lastTelemetryAt,\n    telemetry_age_seconds: ageSeconds,\n    timestamp: now.toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
